{
  "cleanupPeriodDays": 3650,
  "permissions": {
    "allow": [
      "Bash",
      "Bash(curl -s -u *:api_token*api.track.toggl.com*)",
      "Bash(osascript -e *)",
      "Bash(python3 -c *)"
    ]
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/vault/i447/i446/i446-monorepo/scripts/term-color.sh green >/dev/null 2>&1",
            "async": false
          },
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/timing && echo \"{\\\"event\\\":\\\"permission\\\",\\\"ts\\\":\\\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\\\",\\\"date\\\":\\\"$(date +%Y-%m-%d)\\\"}\" >> ~/.claude/timing/permissions.jsonl",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path as $f | (.tool_input.content // .tool_input.new_string // \"\") as $c | if ($f | test(\"^/Users/mckay/vault/\")) and ($c | [splits(\"\\\\n\\\\n\")] | length > 2) then $f else empty end' | { read -r f; [ -n \"$f\" ] && open \"obsidian://open?vault=vault&file=$(python3 -c \"import urllib.parse as u,sys; p=sys.argv[1].replace('/Users/mckay/vault/',''); p=p[:-3] if p.endswith('.md') else p; print(u.quote(p))\" \"$f\")\"; } 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/vault/i447/i446/i446-monorepo/scripts/term-color.sh orange >/dev/null 2>&1",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f /tmp/claude-prayer-token ] || ~/vault/i447/i446/i446-monorepo/scripts/term-color.sh black >/dev/null 2>&1",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/vault/i447/i446/i446-monorepo/scripts/term-color.sh black >/dev/null 2>&1",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "rm -f /tmp/claude-prayer-token; ~/vault/i447/i446/i446-monorepo/scripts/term-color.sh blue >/dev/null 2>&1",
            "async": true
          },
          {
            "type": "command",
            "command": "~/i446-monorepo/scripts/ai-timing-log.sh stop \"$SESSION_ID\" >/dev/null 2>&1",
            "async": true
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/mckay/.claude/sync-stats.sh"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "rm -f /tmp/claude-prayer-token; ~/vault/i447/i446/i446-monorepo/scripts/term-color.sh red >/dev/null 2>&1",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "T=$(date +%s$$); echo \"$T\" > /tmp/claude-prayer-token; ~/vault/i447/i446/i446-monorepo/scripts/term-color.sh purple >/dev/null 2>&1; ( sleep 10; [ \"$(cat /tmp/claude-prayer-token 2>/dev/null)\" = \"$T\" ] && { ~/vault/i447/i446/i446-monorepo/scripts/term-color.sh black >/dev/null 2>&1; rm -f /tmp/claude-prayer-token; } ) &",
            "async": true
          },
          {
            "type": "command",
            "command": "~/i446-monorepo/scripts/ai-timing-log.sh prompt_start \"$SESSION_ID\" >/dev/null 2>&1",
            "async": true
          },
          {
            "type": "command",
            "command": "echo \"{\\\"context\\\": \\\"System date: $(date +%Y-%m-%d) ($(date +%A)). Use this as today's date, not the currentDate context.\\\"}\""
          }
        ]
      }
    ]
  },
  "forceLoginMethod": "console",
  "companyAnnouncements": [
    "Claude Code on Windows can now run PowerShell natively. No more wrapping commands through git bash — Claude writes and executes PowerShell directly, with proper syntax and fewer escaping headaches. See https://code.claude.com/docs/en/tools-reference#powershell-tool to enable this."
  ],
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true
  }
}
