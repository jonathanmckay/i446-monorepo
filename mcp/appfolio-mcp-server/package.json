{
  "name": "@fluegeldao/appfolio-mcp-server",
  "version": "1.1.3",
  "description": "MCP Server for Appfolio API",
  "license": "ISC",
  "author": "CryptoCultCurt <crypto@cryptocult.money>",
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "appfolio-mcp-server": "dist/index.js"
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CryptoCultCurt/appfolio-mcp-server.git"
  },
  "keywords": [
    "appfolio",
    "mcp",
    "api",
    "integration",
    "automation"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --packages=external",
    "build:tsc": "NODE_OPTIONS='--max-old-space-size=8192' tsc",
    "start": "node dist/index.js",
    "start:http": "MCP_MODE=http node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:http": "MCP_MODE=http ts-node src/index.ts",
    "test": "DANGEROUSLY_OMIT_AUTH=true npx @modelcontextprotocol/inspector node ./dist/index.js",
    "build:stytch": "tsc -p tsconfig.stytch.json",
    "start:stytch": "MCP_MODE=http node dist/index-stytch.js",
    "dev:stytch": "MCP_MODE=http ts-node src/index-stytch.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.2",
    "@pipedream/sdk": "^2.0.0-rc.11",
    "@workos-inc/node": "^7.66.0",
    "axios": "^1.6.7",
    "bottleneck": "^2.19.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "jose": "^6.0.12",
    "stytch": "^12.29.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^20.11.30",
    "esbuild": "^0.27.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
