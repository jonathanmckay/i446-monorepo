# AppFolio Leasing Report Configuration
# Copy this file to .env and fill in your values

# ===================
# Google Sheets Setup
# ===================

# Your Google Sheet ID (from the URL)
# Example: https://docs.google.com/spreadsheets/d/THIS_IS_YOUR_SHEET_ID/edit
GOOGLE_SHEET_ID=

# Path to Google service account credentials JSON
# Leave blank to use ./credentials/service_account.json
GOOGLE_SERVICE_ACCOUNT_FILE=

# ==========================
# AppFolio API Setup (Direct)
# ==========================
# If you have direct API access from AppFolio

# Your AppFolio API base URL
# Example: https://yourcompany.appfolio.com/api/v1
APPFOLIO_API_URL=

# Your API credentials
APPFOLIO_CLIENT_ID=
APPFOLIO_CLIENT_SECRET=

# Optional: Custom field mapping (JSON string)
# Example: {"custom_field": "database_field"}
# APPFOLIO_FIELD_MAP=

# ==================
# Skywalk API Setup (Alternative)
# ==================
# Third-party API for AppFolio access
# Sign up at https://skywalkapi.com

# SKYWALK_API_KEY=
# SKYWALK_COMPANY_ID=

# ==================
# Scheduler Settings
# ==================

# Time to run daily sync (24-hour format)
SYNC_TIME=06:00

