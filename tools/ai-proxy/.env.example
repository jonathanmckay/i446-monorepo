# Real Anthropic org API key — never sent to users
ANTHROPIC_API_KEY=sk-ant-...

# Admin key for /admin/turns and /admin/stats endpoints
ADMIN_KEY=your-random-admin-key-here

# Local dev only — overridden to /data/proxy.db on Fly.io
DB_PATH=proxy.db

# Production: set via `fly secrets set USERS_JSON='...'`
# Format: {"pk-user-hex": {"user_id": "jm", "name": "Jonathan McKay", "org": "m5x2", "role": "admin"}}
# USERS_JSON=
