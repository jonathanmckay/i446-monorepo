# i446-monorepo Environment Variables
# Copy this file to .env in relevant project directories and fill in your values

# =============================================================================
# x954-g245.1 (Neon Agent - Goal Tracking)
# =============================================================================
# Microsoft OneDrive OAuth credentials for Excel file access
ONEDRIVE_CLIENT_ID=your_azure_app_client_id_here
ONEDRIVE_CLIENT_SECRET=your_azure_app_client_secret_here

# =============================================================================
# AppFolio Projects (appfolio-attrition, appfolio-leasing-report, appfolio-mcp-server)
# =============================================================================
# AppFolio API credentials (get from AppFolio → Settings → API Credentials)
APPFOLIO_CLIENT_ID=your_appfolio_client_id
APPFOLIO_CLIENT_SECRET=your_appfolio_client_secret
APPFOLIO_BASE_URL=https://yourvhost.appfolio.com

# =============================================================================
# Toggl Integration (if used in any projects)
# =============================================================================
# Toggl API token (get from Toggl → Profile Settings → API Token)
TOGGL_API_TOKEN=your_toggl_api_token
TOGGL_WORKSPACE_ID=your_workspace_id

# =============================================================================
# Todoist Integration (if used in any projects)
# =============================================================================
# Todoist API key (get from Todoist → Settings → Integrations → Developer)
TODOIST_API_KEY=your_todoist_api_key

# =============================================================================
# Google Workspace (if used for Sheets integration)
# =============================================================================
# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# =============================================================================
# GitHub (for commit tracking)
# =============================================================================
# GitHub personal access token (optional, for private repo access)
GITHUB_TOKEN=your_github_token
GITHUB_USER=your_github_username
